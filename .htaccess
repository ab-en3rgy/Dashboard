Options -Indexes
RewriteEngine On

# CORS preflight for api/ext/
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteCond %{REQUEST_URI} ^/api/ext/
RewriteRule ^ api/ext/cors.php [L]

RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^ - [R=204,L]

# Block internal service directories
RewriteRule ^(lib|config|cron|sql)(/.*)?$ - [F,L]

# API ext - route direct .php files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/ext/([a-z_]+)$ api/ext/$1.php [L,QSA]

# API - route direct .php files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^api/([a-z_]+)$ api/$1.php [L,QSA]

# Do not rewrite missing PHP pages to the dashboard.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} \.php$
RewriteRule ^ - [R=404,L]

# Everything else -> index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L,QSA]

<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
</IfModule>

<Files "_bootstrap.php">
    Require all denied
</Files>
